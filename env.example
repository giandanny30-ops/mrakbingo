# ── Discord Bot ──────────────────────────────────────────────────────────────
# Discord Developer Portal → Bot → Reset Token
DISCORD_TOKEN=tvoj_bot_token_ovdje

# Discord Developer Portal → General Information → Application ID
DISCORD_CLIENT_ID=tvoj_application_id

# Desni klik na server → Copy Server ID
DISCORD_GUILD_ID=id_tvog_servera

# Kanal gdje se automatski postavljaju igre (redom, svakih 5 min)
DISCORD_CHANNEL_ID=id_kanala_za_igre

# Kanal gdje idu ban obavijesti (javno vidljivo)
DISCORD_BAN_CHANNEL_ID=id_kanala_za_banove

# Uloga koja se skida na 5 banova
DISCORD_ANTI_BAN_ROLE_ID=id_uloge_za_anti_ban

# Tvoj Discord ID (desni klik na sebe → Copy User ID)
DISCORD_OWNER_ID=tvoj_discord_id
